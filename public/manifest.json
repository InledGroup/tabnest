{
  "manifest_version": 3,
  "name": "TabNest",
  "version": "1.0",
  "description": "Nueva pestaña personalizada con marcadores y noticias.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "bookmarks",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.mitele.es/*", "*://*.mediasetinfinity.es/*"],
      "js": ["assets/streamSync.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.mitele.es/*", "*://*.mediasetinfinity.es/*"],
      "js": ["assets/playerCore.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "16": "tabnest.png",
    "48": "tabnest.png",
    "128": "tabnest.png"
  }
}